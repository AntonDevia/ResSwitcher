<ui:FluentWindow x:Class="ResSwitcher.Settings.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 mc:Ignorable="d"
                 Title="ResSwitcher — настройки"
                 Width="620" Height="760"
                 MinWidth="560" MinHeight="680"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <Style x:Key="RatioTile" TargetType="ui:CardAction" BasedOn="{StaticResource {x:Type ui:CardAction}}">
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Height" Value="100" />
            <Setter Property="Icon" Value="{x:Null}" />
        </Style>
        <Style x:Key="LastRatioTile" TargetType="ui:CardAction" BasedOn="{StaticResource RatioTile}">
            <Setter Property="Margin" Value="0" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="ResSwitcher" Grid.Row="0" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12,24,24">
            <StackPanel>

                <TextBlock Text="Соотношение сторон" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,10" />
                <UniformGrid Columns="3" Rows="1">
                    <ui:CardAction x:Name="Tile4x3" Style="{StaticResource RatioTile}" Click="RatioTile_Click" Tag="4:3">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="48" Height="36" BorderThickness="2" BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" CornerRadius="3" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="4:3" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ui:CardAction>
                    <ui:CardAction x:Name="Tile16x9" Style="{StaticResource RatioTile}" Click="RatioTile_Click" Tag="16:9">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="56" Height="31.5" BorderThickness="2" BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" CornerRadius="3" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="16:9" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ui:CardAction>
                    <ui:CardAction x:Name="Tile16x10" Style="{StaticResource LastRatioTile}" Click="RatioTile_Click" Tag="16:10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="54" Height="33.75" BorderThickness="2" BorderBrush="{DynamicResource TextFillColorPrimaryBrush}" CornerRadius="3" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="16:10" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </ui:CardAction>
                </UniformGrid>

                <TextBlock Text="Разрешение" FontSize="16" FontWeight="SemiBold" Margin="0,26,0,10" />
                <ui:Card Padding="16">
                    <StackPanel>
                        <ComboBox x:Name="ResolutionCombo" SelectionChanged="ResolutionCombo_SelectionChanged" />

                        <CheckBox x:Name="CustomResCheck" Content="Своё разрешение" Margin="0,16,0,8"
                                  Checked="CustomResCheck_CheckedChanged" Unchecked="CustomResCheck_CheckedChanged" />

                        <Grid IsEnabled="{Binding ElementName=CustomResCheck, Path=IsChecked}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ui:NumberBox x:Name="CustomWidthBox" Grid.Column="0" PlaceholderText="Ширина"
                                          Minimum="320" Maximum="7680"
                                          ValueChanged="CustomResBox_ValueChanged" />
                            <TextBlock Grid.Column="1" Text="×" VerticalAlignment="Center" Margin="10,0" FontSize="16" />
                            <ui:NumberBox x:Name="CustomHeightBox" Grid.Column="2" PlaceholderText="Высота"
                                          Minimum="240" Maximum="4320"
                                          ValueChanged="CustomResBox_ValueChanged" />
                        </Grid>

                        <ui:InfoBar x:Name="RatioWarningBar"
                                    Title="Нестрогое соотношение"
                                    Message="Введённое разрешение не совпадает точно с выбранной плиткой (4:3 / 16:9 / 16:10) — картинка будет растянута."
                                    Severity="Warning"
                                    IsOpen="False"
                                    Margin="0,12,0,0" />

                        <CheckBox x:Name="CustomRefreshRateCheck" Content="Своя частота обновления (Гц)" Margin="0,16,0,8"
                                  Checked="CustomRefreshRateCheck_CheckedChanged" Unchecked="CustomRefreshRateCheck_CheckedChanged" />

                        <ui:NumberBox x:Name="RefreshRateBox" PlaceholderText="Герцовка"
                                      Minimum="24" Maximum="480"
                                      IsEnabled="{Binding ElementName=CustomRefreshRateCheck, Path=IsChecked}" />

                        <TextBlock Text="По умолчанию используется текущая частота обновления монитора и не меняется. Включи, только если хочешь задать конкретное значение (например, для режимов с ограниченной герцовкой)."
                                   Opacity="0.6" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ui:Card>

                <TextBlock Text="Поведение" FontSize="16" FontWeight="SemiBold" Margin="0,26,0,10" />
                <ui:Card Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Возвращать системное разрешение при alt-tab" FontWeight="Medium" TextWrapping="Wrap"/>
                                <TextBlock Text="Откат разрешения при потере фокуса игрой" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="RevertOnFocusToggle" Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Запускать ResSwitcher при входе в Windows" FontWeight="Medium" TextWrapping="Wrap"/>
                                <TextBlock Text="Добавляет ярлык автозапуска в текущем профиле" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="StartWithWindowsToggle" Grid.Column="1" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Авто-F11 при возврате в игру" FontWeight="Medium" TextWrapping="Wrap"/>
                                <TextBlock Text="Чинит обрезанный кадр после alt-tab, нажимая F11 дважды за игру" Opacity="0.6" FontSize="12" TextWrapping="Wrap"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="DoubleF11Toggle" Grid.Column="1" VerticalAlignment="Center" Checked="DoubleF11Toggle_CheckedChanged" Unchecked="DoubleF11Toggle_CheckedChanged" />
                        </Grid>

                        <StackPanel x:Name="DoubleF11DelayPanel">
                            <TextBlock Text="Задержка перед F11, мс" FontSize="12" Opacity="0.8" Margin="0,0,0,6"/>
                            <ui:NumberBox x:Name="DoubleF11DelayBox" Minimum="0" Maximum="10000" />
                            <TextBlock Text="Сколько ждать после смены разрешения, прежде чем нажать F11 дважды. Если кадр ещё не появился — F11 может ударить не вовремя и всё сломать; если появился обрезанный кадр — самое время. Подбери опытным путём."
                                       Opacity="0.5" FontSize="11" Margin="0,6,0,0" TextWrapping="Wrap"/>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="12" Opacity="0.8">
                                        <Run Text="Способ отправки: "/>
                                        <Run x:Name="KeyModeLabel" Text="Глобально (как физическая клавиша)" FontWeight="Medium"/>
                                    </TextBlock>
                                    <TextBlock Text="Если игра не реагирует на глобальный ввод — попробуй напрямую в окно, и наоборот."
                                               Opacity="0.5" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="KeyModeToggle" Grid.Column="1" VerticalAlignment="Top"
                                                  OnContent="Напрямую" OffContent="Глобально"
                                                  Checked="KeyModeToggle_CheckedChanged" Unchecked="KeyModeToggle_CheckedChanged" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </ui:Card>

                <ui:Button x:Name="SaveButton" Content="Сохранить" Appearance="Primary"
                           Icon="{ui:SymbolIcon Save24}" Click="SaveButton_Click"
                           Margin="0,28,0,0" Padding="20,10" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                <TextBlock x:Name="StatusText" HorizontalAlignment="Center" TextAlignment="Center"
                           Opacity="0.7" FontSize="12" TextWrapping="Wrap" Margin="0,10,0,0" />
                <TextBlock x:Name="ConfigPathText" HorizontalAlignment="Center" TextAlignment="Center"
                           Opacity="0.45" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
